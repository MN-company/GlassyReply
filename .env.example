TELEGRAM_BOT_TOKEN=123456:replace-me
# Optional: if omitted, the first Telegram user who sends /start claims the bot owner.
TELEGRAM_CHAT_ID=
# Optional: can also be configured later with /setup or /set google_api_key ...
GOOGLE_API_KEY=

DATA_DIR=./data
STATE_DB_PATH=./data/state.db
GMAIL_TOKEN_PATH=./data/token.json
GMAIL_CREDENTIALS_PATH=./data/credentials.json
# Optional: can be uploaded later from Telegram with /setup.
# Paste the full Google OAuth Web client JSON on one line for Fly deploys.
GOOGLE_OAUTH_CREDENTIALS_JSON=
# Optional one-time bootstrap for remote hosts. Written only if token file is missing.
GOOGLE_OAUTH_TOKEN_JSON=

# Optional startup defaults. /setup, /set, and the dashboard can override these at runtime.
PUBLIC_BASE_URL=http://127.0.0.1:8080
WATCH_INTERVAL=15
GMAIL_PUSH_TOPIC=
GMAIL_PUSH_WEBHOOK_SECRET=
LANG=it
AI_MODEL=gemini-1.5-flash
PREDEF_FWD=["redazione@example.com","boss@example.com"]
STATE_RETENTION_DAYS=30

HOST=0.0.0.0
PORT=8080

ENABLE_PIXEL=false
PIXEL_BASE_URL=
PIXEL_WEBHOOK_SECRET=
PIXEL_WEBHOOK_URL=

TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
